# ═══ Production Environment ═══
# Copy this file to .env and fill in the values

# Database — use a cloud MySQL (e.g., PlanetScale, Aiven, Railway MySQL)
DATABASE_URL="mysql://username:password@host:3306/bus_management_system"

# JWT — generate a strong random secret: openssl rand -hex 32
JWT_SECRET="CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET"

# Port — Railway/Render set this automatically
PORT=5000
